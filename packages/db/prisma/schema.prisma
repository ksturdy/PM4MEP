generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Owner
  Admin
  Estimator
  ProjectManager
  Field
  Accounting
}

enum CostType {
  labor
  material
  equipment
  subcontract
  other
}

enum EstimateStatus {
  Draft
  Submitted
  Won
  Lost
}

enum EstimateLineItemSourceType {
  Assembly
  Manual
}

enum ProjectStatus {
  Planning
  Active
  OnHold
  Complete
  Cancelled
}

enum ChangeOrderStatus {
  Draft
  Pending
  Approved
  Rejected
}

enum AssemblyComponentType {
  PriceListItem
  LaborRate
}

enum Plan {
  Essentials
  Growth
  Enterprise
}

enum BillingCycle {
  Monthly
  Annual
}

enum SubscriptionStatus {
  Incomplete
  IncompleteExpired
  Trialing
  Active
  PastDue
  Canceled
  Unpaid
  Paused
}

// Tenant root. Every tenant-scoped table below carries org_id and is
// protected by a Postgres RLS policy (see prisma/rls/001_enable_rls.sql,
// 002_estimating_rls.sql) in addition to being filtered by org_id in
// application code — see apps/api/src/auth/jwt-auth.guard.ts.
model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Proposal letterhead. logoUrl points at an object in Cloudflare R2
  // (apps/api/src/storage/r2.service.ts) — the client uploads directly to
  // R2 via a presigned URL, then PATCHes this field with the resulting
  // public URL, so this column never stores anything but a URL.
  addressLine1  String? @map("address_line1")
  addressLine2  String? @map("address_line2")
  city          String?
  state         String?
  postalCode    String? @map("postal_code")
  phone         String?
  email         String?
  licenseNumber String? @map("license_number")
  logoUrl       String? @map("logo_url")

  // Stripe subscription state. subscriptionStatus starts Incomplete at
  // signup (see AuthService.register) and is only ever advanced by the
  // billing webhook handler — never written to directly by application
  // code — so it always reflects Stripe's own view of the subscription.
  plan                 Plan               @default(Essentials)
  billingCycle         BillingCycle?      @map("billing_cycle")
  subscriptionStatus   SubscriptionStatus @default(Incomplete) @map("subscription_status")
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  stripePriceId        String?            @map("stripe_price_id")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  trialEndsAt          DateTime?          @map("trial_ends_at")

  memberships    Membership[]
  invitations    Invitation[]
  costCodes      CostCode[]
  customers      Customer[]
  priceListItems PriceListItem[]
  laborRates     LaborRate[]
  assemblies     Assembly[]
  estimates      Estimate[]
  projects       Project[]
  orgSequences   OrgSequence[]

  @@map("organizations")
}

// Records every processed Stripe webhook event id so redeliveries (Stripe
// retries on any non-2xx response, and can also send outright duplicates)
// are safely ignored instead of double-applied. No org_id — the org isn't
// known until the event payload is parsed — so this table is intentionally
// outside RLS, same as `users`.
model StripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("stripe_events")
}

// Credentials + identity. passwordHash is bcrypt (see apps/api/src/auth/auth.service.ts);
// plaintext passwords are never stored or logged.
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  memberships         Membership[]
  createdEstimates    Estimate[]
  passwordResets      PasswordReset[]
  createdProjects     Project[]          @relation("ProjectCreatedBy")
  managedProjects     Project[]          @relation("ProjectManager")
  projectCostEntries  ProjectCostEntry[]
  createdChangeOrders ChangeOrder[]

  @@map("users")
}

// Password reset tokens, both admin-triggered (Owner/Admin resets a
// teammate's password from Settings > Team) and self-service (the
// "Forgot password?" link on /login). Not RLS-scoped — same reasoning as
// Invitation: looked up by a unique random token the requester already
// possesses (from the emailed link), and users itself isn't org-scoped.
// tokenHash, not the raw token, is stored, same as Invitation.
model PasswordReset {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

// Join table between User and Organization. Modeled explicitly (rather than
// a role column on User) so a user can belong to more than one org later
// without a schema migration.
model Membership {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  orgId     String   @map("org_id")
  role      Role
  createdAt DateTime @default(now()) @map("created_at")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
  @@map("memberships")
}

// Pending team invites. Not RLS-scoped, same reasoning as `organizations`
// (see prisma/rls/001_enable_rls.sql): the accept flow looks this up by a
// unique random token the invitee already legitimately possesses (from the
// emailed link), not by any org-scoped listing, so RLS earns nothing here
// and would actively break the unauthenticated accept-invite lookup. The
// authenticated team-management endpoints (list/revoke pending invites)
// still filter by orgId explicitly in the query, same double-safety
// pattern used elsewhere. tokenHash, not the raw token, is stored — same
// defense-in-depth reasoning as password hashing.
model Invitation {
  id         String    @id @default(uuid())
  orgId      String    @map("org_id")
  email      String
  role       Role
  tokenHash  String    @unique @map("token_hash")
  invitedBy  String    @map("invited_by")
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@index([orgId])
  @@map("invitations")
}

// Seeded with standard MCAA/NECA-style codes per org on creation; editable
// per org thereafter. Referenced by price list items, labor rates, and
// estimate line items — the spine that ties estimating and (later) project
// management together. Retire a code by setting active: false rather than
// deleting it (referencing rows use onDelete: Restrict).
model CostCode {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  code        String
  description String
  costType    CostType @map("cost_type")
  defaultUnit String   @map("default_unit")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org                Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  priceListItems     PriceListItem[]
  laborRates         LaborRate[]
  estimateLineItems  EstimateLineItem[]
  projectBudgetLines ProjectBudgetLine[]
  projectCostEntries ProjectCostEntry[]

  @@unique([orgId, code])
  @@index([orgId])
  @@map("cost_codes")
}

// No separate Contact model in Phase 1 — a per-estimate "bid to" override
// (see Estimate.bidToContactName/Email/Phone) covers proposals addressed to
// someone other than the customer's general contact, more cheaply than a
// full CRM contact table this phase doesn't need yet.
model Customer {
  id                  String   @id @default(uuid())
  orgId               String   @map("org_id")
  name                String
  addressLine1        String   @map("address_line1")
  addressLine2        String?  @map("address_line2")
  city                String
  state               String
  postalCode          String   @map("postal_code")
  primaryContactName  String?  @map("primary_contact_name")
  primaryContactEmail String?  @map("primary_contact_email")
  primaryContactPhone String?  @map("primary_contact_phone")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  estimates Estimate[]
  projects  Project[]

  @@index([orgId])
  @@index([orgId, name])
  @@map("customers")
}

// Material/equipment catalog. No own costType — always inherits live from
// costCodeId (no snapshot need until something enters an estimate; see
// EstimateLineItem for where snapshotting actually matters).
model PriceListItem {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  costCodeId   String   @map("cost_code_id")
  description  String
  manufacturer String?
  modelNumber  String?  @map("model_number")
  sku          String?
  unit         String
  unitCost     Decimal  @map("unit_cost") @db.Decimal(12, 4)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  costCode CostCode     @relation(fields: [costCodeId], references: [id], onDelete: Restrict)

  assemblyComponents AssemblyComponent[]
  estimateLineItems  EstimateLineItem[]

  @@index([orgId])
  @@index([orgId, costCodeId])
  @@map("price_list_items")
}

// Crew classification + fully-burdened hourly rate (burden already folded
// in — matches how contractors actually think about labor cost). Same
// non-redundant costType rule as PriceListItem.
model LaborRate {
  id                 String   @id @default(uuid())
  orgId              String   @map("org_id")
  costCodeId         String   @map("cost_code_id")
  classification     String
  burdenedHourlyRate Decimal  @map("burdened_hourly_rate") @db.Decimal(12, 4)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  costCode CostCode     @relation(fields: [costCodeId], references: [id], onDelete: Restrict)

  assemblyComponents AssemblyComponent[]
  estimateLineItems  EstimateLineItem[]

  @@unique([orgId, classification])
  @@index([orgId])
  @@map("labor_rates")
}

// A reusable "recipe" (e.g. "3-Ton RTU Install") — unit is what the recipe
// scales against when exploded into an estimate at a given quantity.
model Assembly {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  unit        String
  category    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  components AssemblyComponent[]

  estimateLineItems EstimateLineItem[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("assemblies")
}

// A labor or material line inside an Assembly recipe. Exactly one of
// priceListItemId/laborRateId is populated — enforced in Zod at the API
// boundary, plus a hand-written Postgres CHECK constraint (see
// prisma/rls/002_estimating_rls.sql) since Prisma can't express that
// invariant declaratively. No separate "hours" field: when componentType is
// LaborRate, quantityPerUnit *is* hours-per-assembly-unit.
model AssemblyComponent {
  id              String                @id @default(uuid())
  orgId           String                @map("org_id")
  assemblyId      String                @map("assembly_id")
  componentType   AssemblyComponentType @map("component_type")
  priceListItemId String?               @map("price_list_item_id")
  laborRateId     String?               @map("labor_rate_id")
  quantityPerUnit Decimal               @map("quantity_per_unit") @db.Decimal(12, 4)
  sortOrder       Int                   @map("sort_order")

  assembly      Assembly       @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  priceListItem PriceListItem? @relation(fields: [priceListItemId], references: [id], onDelete: Restrict)
  laborRate     LaborRate?     @relation(fields: [laborRateId], references: [id], onDelete: Restrict)

  @@index([orgId])
  @@index([assemblyId])
  @@map("assembly_components")
}

// Generic per-org counter, reused for estimate numbers now and invoice
// numbers etc. in a later phase without a new table. Incremented via
// `UPDATE ... SET current_value = current_value + 1 RETURNING current_value`
// inside the same transaction that creates the numbered row, so the row
// lock serializes concurrent numbering within an org.
model OrgSequence {
  orgId        String @map("org_id")
  key          String
  currentValue Int    @default(0) @map("current_value")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([orgId, key])
  @@map("org_sequences")
}

// Markup config is typed columns directly on Estimate, not JSON and not a
// separate 1:1 table — the cost-type set is fixed (5 values matching
// CostType), and JSON would lose Decimal precision for no flexibility
// payoff at this stage. calculatedSellPrice is always server-computed and
// overwritten on save, never client-trusted; finalSellPriceOverride is
// nullable ("use calculated" when null) so the two stay distinguishable for
// later estimate-accuracy reporting. taxPct is applied on top of the
// resolved (post-override) price for display/PDF purposes — see
// packages/domain's resolveSellPriceWithTax — so the override always
// represents the negotiated pre-tax price.
model Estimate {
  id         String         @id @default(uuid())
  orgId      String         @map("org_id")
  customerId String         @map("customer_id")
  number     String
  name       String
  status     EstimateStatus @default(Draft)

  bidDueDate        DateTime? @map("bid_due_date")
  bidToContactName  String?   @map("bid_to_contact_name")
  bidToContactEmail String?   @map("bid_to_contact_email")
  bidToContactPhone String?   @map("bid_to_contact_phone")

  createdById String @map("created_by_id")

  laborMarkupPct       Decimal @map("labor_markup_pct") @db.Decimal(5, 2)
  materialMarkupPct    Decimal @map("material_markup_pct") @db.Decimal(5, 2)
  equipmentMarkupPct   Decimal @map("equipment_markup_pct") @db.Decimal(5, 2)
  subcontractMarkupPct Decimal @map("subcontract_markup_pct") @db.Decimal(5, 2)
  otherMarkupPct       Decimal @map("other_markup_pct") @db.Decimal(5, 2)
  overheadPct          Decimal @map("overhead_pct") @db.Decimal(5, 2)
  profitPct            Decimal @map("profit_pct") @db.Decimal(5, 2)
  contingencyPct       Decimal @map("contingency_pct") @db.Decimal(5, 2)
  taxPct               Decimal @map("tax_pct") @db.Decimal(5, 2)

  calculatedSellPrice    Decimal  @map("calculated_sell_price") @db.Decimal(12, 2)
  finalSellPriceOverride Decimal? @map("final_sell_price_override") @db.Decimal(12, 2)

  scopeDescription   String? @map("scope_description")
  inclusions         String?
  exclusions         String?
  termsAndConditions String? @map("terms_and_conditions")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer  Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy User         @relation(fields: [createdById], references: [id], onDelete: Restrict)

  sections EstimateSection[]
  // At most one Project per estimate — see Project.estimateId. Won -> Draft
  // is blocked in EstimatingService.transitionStatus() once this is set, so
  // a converted estimate can't be reverted out from under its Project.
  project  Project?

  @@unique([orgId, number])
  @@index([orgId])
  @@index([orgId, customerId])
  @@index([orgId, status])
  @@index([orgId, bidDueDate])
  @@map("estimates")
}

model EstimateSection {
  id         String @id @default(uuid())
  orgId      String @map("org_id")
  estimateId String @map("estimate_id")
  name       String
  sortOrder  Int    @map("sort_order")

  estimate  Estimate           @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  lineItems EstimateLineItem[]

  @@index([orgId])
  @@index([estimateId])
  @@map("estimate_sections")
}

// Estimate scope is derived by joining through sectionId, not a redundant
// separate estimateId FK — avoids a sync-risk footgun where the two could
// disagree. costCodeId and costType intentionally coexist: costCodeId is a
// traceability pointer to whatever cost code was current at entry time
// (nullable, SetNull), while costType is the frozen classification used for
// markup rollup math, captured at snapshot time — if a CostCode's
// classification is later corrected, already-submitted estimates must not
// silently reclassify. No separate laborHours field: when unit = "HR",
// quantity *is* hours.
model EstimateLineItem {
  id              String                     @id @default(uuid())
  orgId           String                     @map("org_id")
  sectionId       String                     @map("section_id")
  sourceType      EstimateLineItemSourceType @map("source_type")
  assemblyId      String?                    @map("assembly_id")
  priceListItemId String?                    @map("price_list_item_id")
  laborRateId     String?                    @map("labor_rate_id")
  costCodeId      String?                    @map("cost_code_id")

  description  String
  unit         String
  unitCost     Decimal  @map("unit_cost") @db.Decimal(12, 4)
  quantity     Decimal  @db.Decimal(12, 4)
  extendedCost Decimal  @map("extended_cost") @db.Decimal(12, 2)
  costType     CostType @map("cost_type")

  markupOverridePct Decimal? @map("markup_override_pct") @db.Decimal(5, 2)
  sortOrder         Int      @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  section       EstimateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  assembly      Assembly?       @relation(fields: [assemblyId], references: [id], onDelete: SetNull)
  priceListItem PriceListItem?  @relation(fields: [priceListItemId], references: [id], onDelete: SetNull)
  laborRate     LaborRate?      @relation(fields: [laborRateId], references: [id], onDelete: SetNull)
  costCode      CostCode?       @relation(fields: [costCodeId], references: [id], onDelete: SetNull)

  // Populated on rows copied into a Project's budget at Won-estimate
  // conversion time (see ProjectBudgetLine.sourceEstimateLineItemId) — a
  // given line item is never copied more than once per project, but nothing
  // stops the same source line item being referenced by budget lines across
  // more than one project over time (e.g. a rejected then re-created
  // conversion), hence the array rather than a 1:1 back-relation.
  projectBudgetLines ProjectBudgetLine[]

  @@index([orgId])
  @@index([sectionId])
  @@map("estimate_line_items")
}

// A Project tracks execution of already-sold work: budget vs. actual cost,
// schedule milestones, and change orders. Created either by converting a
// Won Estimate (estimateId set, budget lines snapshotted 1:1 from the
// estimate's line items — see ProjectBudgetLine) or from scratch
// (estimateId null, budget lines entered manually) — both paths produce the
// same shape of Project. totalBudget/totalActualCost are always
// server-computed and overwritten on save, never client-trusted, same rule
// as Estimate.calculatedSellPrice — see recalculate() in
// apps/api/src/projects/projects.service.ts.
model Project {
  id         String        @id @default(uuid())
  orgId      String        @map("org_id")
  customerId String        @map("customer_id")
  estimateId String?       @unique @map("estimate_id")
  number     String
  name       String
  status     ProjectStatus @default(Planning)

  startDate            DateTime? @map("start_date")
  targetCompletionDate DateTime? @map("target_completion_date")
  actualCompletionDate DateTime? @map("actual_completion_date")

  projectManagerId String? @map("project_manager_id")
  scopeDescription String? @map("scope_description")

  totalBudget     Decimal @map("total_budget") @db.Decimal(12, 2)
  totalActualCost Decimal @map("total_actual_cost") @db.Decimal(12, 2)

  createdById String @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  estimate       Estimate?    @relation(fields: [estimateId], references: [id], onDelete: Restrict)
  createdBy      User         @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  projectManager User?        @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: SetNull)

  budgetLines  ProjectBudgetLine[]
  costEntries  ProjectCostEntry[]
  milestones   ProjectMilestone[]
  changeOrders ChangeOrder[]

  @@unique([orgId, number])
  @@index([orgId])
  @@index([orgId, customerId])
  @@index([orgId, status])
  @@index([orgId, projectManagerId])
  @@map("projects")
}

// Budget lines are always a snapshot, never a live join — either copied 1:1
// from a Won estimate's line items at conversion time
// (sourceEstimateLineItemId set) or entered manually for a from-scratch
// project (null). Mirrors why EstimateLineItem itself snapshots assembly
// pricing rather than joining live: nothing blocks editing a Won estimate's
// line items afterward, so the snapshot is what protects a live project's
// budget from drifting under it. No qty/unitCost breakdown here (unlike
// EstimateLineItem) — a budget line is a target dollar amount, not a build-up.
model ProjectBudgetLine {
  id                       String  @id @default(uuid())
  orgId                    String  @map("org_id")
  projectId                String  @map("project_id")
  costCodeId               String? @map("cost_code_id")
  sourceEstimateLineItemId String? @map("source_estimate_line_item_id")

  description  String
  costType     CostType @map("cost_type")
  budgetAmount Decimal  @map("budget_amount") @db.Decimal(12, 2)
  sortOrder    Int      @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project                Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costCode               CostCode?         @relation(fields: [costCodeId], references: [id], onDelete: SetNull)
  sourceEstimateLineItem EstimateLineItem? @relation(fields: [sourceEstimateLineItemId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([projectId])
  @@map("project_budget_lines")
}

// The actual-cost ledger — what field crews and accounting log against a
// project's budget, one entry per cost incurred. enteredById (not
// createdById, deliberately) is the person who logged the cost, distinct
// from incurredOn, the date the cost was actually incurred.
model ProjectCostEntry {
  id         String  @id @default(uuid())
  orgId      String  @map("org_id")
  projectId  String  @map("project_id")
  costCodeId String? @map("cost_code_id")

  description  String
  costType     CostType @map("cost_type")
  quantity     Decimal  @db.Decimal(12, 4)
  unitCost     Decimal  @map("unit_cost") @db.Decimal(12, 4)
  extendedCost Decimal  @map("extended_cost") @db.Decimal(12, 2)
  incurredOn   DateTime @map("incurred_on")

  enteredById String @map("entered_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costCode  CostCode? @relation(fields: [costCodeId], references: [id], onDelete: SetNull)
  enteredBy User      @relation(fields: [enteredById], references: [id], onDelete: Restrict)

  @@index([orgId])
  @@index([projectId])
  @@map("project_cost_entries")
}

// Flat date markers, not a full Gantt/critical-path schedule — an
// intentional Phase 1 scope cut, same kind of call as Customer's "no
// separate Contact model" comment above.
model ProjectMilestone {
  id          String    @id @default(uuid())
  orgId       String    @map("org_id")
  projectId   String    @map("project_id")
  name        String
  dueDate     DateTime? @map("due_date")
  completedAt DateTime? @map("completed_at")
  sortOrder   Int       @map("sort_order")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([projectId])
  @@index([orgId, dueDate])
  @@map("project_milestones")
}

// amount is a signed budget delta, folded into Project.totalBudget only
// once Approved (see recalculate() in projects.service.ts) — Draft/Pending/
// Rejected change orders never affect the budget. scheduleImpactDays is
// nullable since not every change order shifts the completion date.
model ChangeOrder {
  id                 String            @id @default(uuid())
  orgId              String            @map("org_id")
  projectId          String            @map("project_id")
  title              String
  description        String?
  status             ChangeOrderStatus @default(Draft)
  amount             Decimal           @db.Decimal(12, 2)
  scheduleImpactDays Int?              @map("schedule_impact_days")
  approvedAt         DateTime?         @map("approved_at")

  createdById String @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([orgId])
  @@index([projectId])
  @@index([orgId, status])
  @@map("change_orders")
}
