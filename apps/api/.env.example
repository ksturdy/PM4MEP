PORT=4000
WEB_APP_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://user:password@localhost:5432/pm4mep

# Random long secret used to sign/verify session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Rotating this invalidates every existing session.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Stripe test-mode secret key (dashboard: Developers > API keys).
STRIPE_SECRET_KEY=
# Printed by `stripe listen --forward-to localhost:4000/billing/webhook`
# locally, or by the Dashboard's webhook endpoint config in production.
STRIPE_WEBHOOK_SECRET=
# Printed by `pnpm --filter @pm4mep/api stripe:setup` (run once with a real
# STRIPE_SECRET_KEY — see apps/api/scripts/stripe-setup.ts).
STRIPE_PRICE_ESSENTIALS_MONTHLY=
STRIPE_PRICE_ESSENTIALS_ANNUAL=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=
# Days of trial before the first charge; 0 disables the trial.
TRIAL_PERIOD_DAYS=14
